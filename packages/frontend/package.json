{
    "name": "frontend",
    "version": "1.0.0",
    "scripts": {
      "stylelint": "stylelint  './src/**/*.scss'",
      "stylelint:fix": "stylelint .'/src/**/*.scss'  --fix",
      "eslint": "eslint --ext .ts,.tsx './src'",
      "start": "APP_MODE=local TS_NODE_PROJECT=\"webpack.tsconfig.json\" NODE_ENV=development webpack-dev-server   --output-pathinfo --hot --host localhost --port 4001 --mode development",
      "start:https": "yarn start --https --open",
      "build": "TS_NODE_PROJECT=\"webpack.tsconfig.json\" webpack --mode production",
      "build:analyze": "TS_NODE_PROJECT=\"webpack.tsconfig.json\" ANALYZE=true webpack --mode production",
      "server": "ts-node src/backend/server.ts",
      "test": "jest",
      "typecheck": "tsc --project tsconfig.json",
      "server:dev": "node ./nodemon-process-stop.js && nodemon",
      "server:dev:db": "docker run  -d -p 27017:27017 -v $(pwd)/mongo-db:/data/db mongo",
      "depcheck": "depcruise --config .dependency-cruiser.js src",
      "scheme:generate": "gqty generate"
    },
    "dependencies": {
      "atomic-router": "~0.5.0-dev.20",
